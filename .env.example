# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback/discord

# Discord bot (shared by announcements + shoutbox)
# In Developer Portal → Bot → enable "Message Content Intent" for shoutbox text reads.
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_discord_server_id
DISCORD_ANNOUNCEMENT_CHANNEL_ID=your_announcement_channel_id

# Discord Shoutbox (live chat drawer — webhook posts as SHOUTBOX_USERNAME)
DISCORD_SHOUTBOX_CHANNEL_ID=your_shoutbox_channel_id
DISCORD_SHOUTBOX_WEBHOOK_URL=https://discord.com/api/webhooks/...
SHOUTBOX_POST_PASSWORD=your-secret-password
SHOUTBOX_USERNAME=cooldude67

# Session encryption (use a random 32+ character string)
SESSION_SECRET=replace_with_a_long_random_secret_string

# Optional: base URL for production redirects
NEXT_PUBLIC_BASE_URL=http://localhost:3000
